.DS_Store
Thumbs.db

# Local/editor state
.vscode/
.idea/
*.swp
*.swo

# Local dependency/cache/build folders for future iterations
node_modules/
dist/
build/
.worktrees/
worktrees/
tools/**/bin/
tools/**/obj/

# Logs and temporary files
*.log
*.tmp
*.temp

# Runtime generated draft images
wwwroot/assets/generated/draft-*.png
wwwroot/assets/generated/draft-*.jpg
wwwroot/assets/generated/draft-*.jpeg
wwwroot/assets/generated/draft-*.webp
wwwroot/assets/generated/*-current.png
wwwroot/assets/generated/level_*.png
wwwroot/assets/generated/level_*/
!wwwroot/assets/generated/.gitkeep
handoff/requests/*.md
handoff/requests/*.json
handoff/requests/elements/
handoff/requests/level_*/
!handoff/requests/.gitkeep
handoff/results/*
!handoff/results/.gitkeep
